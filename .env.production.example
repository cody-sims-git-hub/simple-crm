# Production environment for SimpleCRM (copy to .env on the server).
# Generate APP_KEY with:  echo "base64:$(openssl rand -base64 32)"

APP_NAME=SimpleCRM
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://demo.simsdigitalpartners.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Containers log to stdout/stderr -> visible via `docker compose logs`
LOG_CHANNEL=stderr
LOG_LEVEL=error

# SQLite, persisted on the crm-data volume mounted at /data
DB_CONNECTION=sqlite
DB_DATABASE=/data/database.sqlite

# Sessions/cache use the database (tables ship in the base migrations)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=sync
